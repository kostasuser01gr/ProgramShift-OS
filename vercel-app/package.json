  "devDependencies": {
    "@types/node": "20.14.10",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "eslint": "8.57.1",
    "eslint-config-next": "15.5.19",
    "tsx": "4.20.6",
    "typescript": "5.5.4"
  },
  "overrides": {
    "postcss": "^8.5.15",
    "uuid": "^11.1.1"
