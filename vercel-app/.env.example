# ── Google service account (server-side Sheets access) ──────────────────────
# Create a service account in Google Cloud, enable the Sheets API, download the
# JSON key, and SHARE THE SPREADSHEET with the service account email (Viewer is
# enough for reads; Editor if the app writes cells).
GOOGLE_SA_EMAIL=shift-bot@your-project.iam.gserviceaccount.com
# Paste the private_key from the JSON. Keep the literal \n escapes on one line.
GOOGLE_SA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"

# The spreadsheet to read/write (the ID from the sheet URL).
SCHEDULE_SHEET_ID=19sgjHBZWvDkA-4QSIKzjn8jY_7RjNby-p9Czw-nJkm8

# ── NextAuth (Google sign-in) ───────────────────────────────────────────────
# OAuth client (type: Web). Authorised redirect URI:
#   http://localhost:3000/api/auth/callback/google  (and your prod URL)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXTAUTH_SECRET=run_`openssl rand -base64 32`
NEXTAUTH_URL=http://localhost:3000
# Comma-separated Google account emails authorized for elevated access.
OWNER_EMAILS=owner@your-company.example
MANAGER_EMAILS=manager@your-company.example

# ── Webhook shared secret (Apps Script → app) ───────────────────────────────
# Any long random string. Put the SAME value in the Apps Script Script Property
# APP_WEBHOOK_SECRET, and the webhook URL in APP_WEBHOOK_URL.
WEBHOOK_SECRET=replace-with-at-least-24-random-characters
